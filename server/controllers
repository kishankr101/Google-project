const Room = require('../models/Room');

exports.getRooms = async (req, res) => {
    try {
        const { location, fromDate, toDate } = req.query;
        let query = {};
        
        if (location) query.location = { $regex: location, $options: 'i' };

        const rooms = await Room.find(query);
        
        // Filter out unavailable rooms based on date overlap
        if (fromDate && toDate) {
            const checkIn = new Date(fromDate);
            const checkOut = new Date(toDate);
            
            const availableRooms = rooms.filter(room => {
                return!room.bookings.some(b => 
                    (checkIn < new Date(b.to) && checkOut > new Date(b.from))
                );
            });
            return res.json(availableRooms);
        }

        res.json(rooms);
    } catch (err) {
        res.status(500).json({ message: err.message });
    }
};
