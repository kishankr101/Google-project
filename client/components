import React, { useState, useContext } from 'react';
import { RoomContext } from '../context/RoomContext';

const SearchBar = () => {
    const [loc, setLoc] = useState('');
    const { fetchRooms } = useContext(RoomContext);

    return (
        <div className="flex bg-white p-4 rounded-full shadow-xl max-w-4xl mx-auto -mt-8">
            <input 
                className="flex-1 px-4 outline-none border-r" 
                placeholder="Where are you going?"
                onChange={(e) => setLoc(e.target.value)}
            />
            <button 
                className="bg-red-500 text-white px-8 py-2 rounded-full font-bold ml-4 hover:bg-red-600 transition"
                onClick={() => fetchRooms({ location: loc })}
            >
                Search
            </button>
        </div>
    );
};

